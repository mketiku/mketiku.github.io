---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import profileImage from '../assets/profile.jpeg';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Michael Ketiku | Senior Software Engineer" scrollSpy={true}>
    <section id="hero" class="container d-flex align-items-center min-vh-100">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="card border-0 shadow-lg overflow-hidden" data-aos="fade-up">
                    <div class="row g-0">
                        <div class="col-md-7 d-flex align-items-center bg-body-tertiary">
                            <div class="card-body p-4 p-lg-5">
                                <h2 class="h3 text-secondary mb-3">Hello! 👋🏾</h2>
                                <h1 class="hero-name mb-3">
                                    I'm <span class="text-theme">Michael Ketiku</span>
                                </h1>
                                <div class="hero-shuffle-container mb-4">
                                    <span id="hero-title" class="hero-title-text">Software Engineer</span>
                                    <span class="hero-separator"></span>
                                    <button id="shuffle-btn" class="btn btn-link text-decoration-none"
                                        aria-label="Shuffle Title">
                                        <i class="fas fa-shuffle"></i>
                                    </button>
                                </div>
                                <div class="d-flex gap-4">

                                    <a href="https://www.linkedin.com/in/mketiku/" target="_blank" class="social-link" aria-label="LinkedIn Profile">
                                        <i class="fab fa-linkedin"></i>
                                    </a>
                                    <a href="https://github.com/mketiku" target="_blank" class="social-link" aria-label="GitHub Profile">
                                        <i class="fab fa-github"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-5 position-relative">
                            <Image 
                                src={profileImage} 
                                class="img-fluid h-100 w-100 object-fit-cover"
                                alt="Michael Ketiku" 
                                style="min-height: 300px;"
                                loading="eager"
                            />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="about" class="bg-body-tertiary">
        <div class="container">
            <h2 class="section-title" data-aos="fade-right">About</h2>
            <div class="row">
                <div class="col-lg-8 mb-5">
                    <p class="lead text-secondary" data-aos="fade-up">
                        I am a Senior Software Engineer based in New York, passionate about building scalable platforms
                        and modernizing legacy systems. With a strong foundation in both technical leadership and
                        hands-on development, I strive to create efficient, user-centric solutions.
                    </p>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <h4 class="mb-3 text-theme">Languages & Frameworks</h4>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge rounded-pill badge-skill">Python</span>
                        <span class="badge rounded-pill badge-skill">Java</span>
                        <span class="badge rounded-pill badge-skill">Kotlin</span>
                        <span class="badge rounded-pill badge-skill">JavaScript</span>
                        <span class="badge rounded-pill badge-skill">Django</span>
                        <span class="badge rounded-pill badge-skill">Spring Boot</span>
                        <span class="badge rounded-pill badge-skill">Flask</span>
                        <span class="badge rounded-pill badge-skill">SQL</span>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <h4 class="mb-3 text-theme">DevOps & Tech</h4>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge rounded-pill badge-skill">Kubernetes</span>
                        <span class="badge rounded-pill badge-skill">Docker</span>
                        <span class="badge rounded-pill badge-skill">Terraform</span>
                        <span class="badge rounded-pill badge-skill">AWS ECS/RDS</span>
                        <span class="badge rounded-pill badge-skill">Kafka</span>
                        <span class="badge rounded-pill badge-skill">Redis</span>
                        <span class="badge rounded-pill badge-skill">Jenkins</span>
                        <span class="badge rounded-pill badge-skill">AI/LLMs</span>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <h4 class="mb-3 text-theme">Methodologies</h4>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge rounded-pill badge-skill">Agile</span>
                        <span class="badge rounded-pill badge-skill">Scrum</span>
                        <span class="badge rounded-pill badge-skill">Microservices</span>
                        <span class="badge rounded-pill badge-skill">Test-Driven Development (TDD)</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="experience" class="container">
        <h2 class="section-title" data-aos="fade-right">Experience</h2>
        <div class="row g-4">

            <div class="col-12" data-aos="fade-up">
                <div class="card p-4 h-100">
                    <div class="d-flex flex-column flex-md-row justify-content-between mb-2">
                        <h4 class="fw-bold">Lead Software Engineer</h4>
                        <span class="text-theme fw-bold">JPMorgan Chase & Co.</span>
                    </div>
                    <div class="text-muted small mb-3">New York, NY | February 2020 – Present</div>
                    <p class="mb-0">Led platform modernization initiatives, mentored junior developers and provided
                        critical production support.</p>
                </div>
            </div>

            <div class="col-12" data-aos="fade-up">
                <div class="card p-4 h-100">
                    <div class="d-flex flex-column flex-md-row justify-content-between mb-2">
                        <h4 class="fw-bold">Software Engineer</h4>
                        <span class="text-theme fw-bold">Federal Reserve Bank of New York</span>
                    </div>
                    <div class="text-muted small mb-3">New York, NY | December 2018 – February 2020</div>
                    <p class="mb-0">Developed foundational Python modules and full-stack reporting solutions while
                        establishing best practices for the analytics team.</p>
                </div>
            </div>

            <div class="col-12" data-aos="fade-up">
                <div class="card p-4 h-100">
                    <div class="d-flex flex-column flex-md-row justify-content-between mb-2">
                        <h4 class="fw-bold">Software Engineer</h4>
                        <span class="text-theme fw-bold">Indiana General Assembly</span>
                    </div>
                    <div class="text-muted small mb-3">Indianapolis, IN | May 2017 – August 2018</div>
                    <p class="mb-0">Built video management applications and automated legislative reporting tools,
                        reducing manual processes from hours to seconds.</p>
                </div>
            </div>

        </div>
    </section>

    <section id="projects" class="bg-body-tertiary">
        <div class="container">
            <h2 class="section-title" data-aos="fade-right">Projects</h2>
            <div class="row g-4">
                {projects.map((project, index) => (
                    <div class="col-md-6" data-aos="fade-up" data-aos-delay={(index + 1) * 100}>
                        <div class="card p-4 h-100">
                            <h3 class="h4 fw-bold mb-3">{project.data.title}</h3>
                            <p class="text-secondary">{project.data.description}</p>
                            <a 
                                href={project.data.link} 
                                target={project.data.link.startsWith('http') ? "_blank" : "_self"}
                                class="text-theme text-decoration-none fw-bold mt-auto"
                            >
                                {project.data.link.startsWith('http') ? 'Visit Project' : 'View Project'}
                                <i class="fas fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section id="education" class="container">
        <h2 class="section-title" data-aos="fade-right">Education & Certifications</h2>

        <div class="row">
            <div class="col-md-6 mb-5" data-aos="fade-up">
                <h3 class="h5 text-theme mb-4">Degrees</h3>
                <div class="mb-4 border-start border-2 ps-3">
                    <div class="fw-bold">M.Sc. Information Systems, Business Intelligence</div>
                    <div class="text-muted">Pace University, NY | 2020 - 2021</div>
                </div>
                <div class="border-start border-2 ps-3">
                    <div class="fw-bold">B.Sc. Computer Science</div>
                    <div class="text-muted">Butler University, IN | 2013 - 2017</div>
                </div>
            </div>

            <div class="col-md-6 mb-5" data-aos="fade-up" data-aos-delay="100">
                <h3 class="h5 text-theme mb-4">Certifications</h3>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="fas fa-check text-theme me-2"></i> Project Management Professional (PMP)</li>
                    <li class="mb-2"><i class="fas fa-check text-theme me-2"></i> Advanced Certified Scrum Product Owner</li>
                    <li class="mb-2"><i class="fas fa-check text-theme me-2"></i> Product Management Certification (Product School)</li>
                    <li class="mb-2"><i class="fas fa-check text-theme me-2"></i> AWS Certified Cloud Practitioner</li>
                    <li class="mb-2"><i class="fas fa-check text-theme me-2"></i> Certified Scrum Product Owner (CSPO)</li>
                    <li class="mb-2"><i class="fas fa-check text-theme me-2"></i> Certified ScrumMaster (CSM)</li>
                </ul>
            </div>
        </div>

        <div class="row" data-aos="fade-up">
            <div class="col-12">
                <h3 class="h5 text-theme mb-3">Volunteer Activities</h3>
                <p class="mb-1"><strong>Engin Program:</strong> English Language Tutor (2025 - Present)</p>
                <p class="mb-1"><strong>Streetwise Partners:</strong> Mentor (2020 - Present)</p>
                <p class="mb-1"><strong>New York Cares:</strong> Volunteer (2020 - Present)</p>
                <p class="mb-1"><strong>Xavier Mission:</strong> Pantry Service (2019 - 2021)</p>
            </div>
        </div>
    </section>

    <section id="contact" class="bg-body-tertiary text-center">
        <div class="container">
            <h2 class="section-title d-inline-block" data-aos="fade-up">Contact Me</h2>
            <div class="row justify-content-center mt-4">
                <div class="col-lg-8">
                    <p class="fs-4 text-secondary" data-aos="fade-up" data-aos-delay="100">
                        I'm always open to discussing new opportunities (particularly volunteering), interesting
                        projects, or just having a chat about technology.
                    </p>
                    <div class="d-flex justify-content-center gap-3 mt-4" data-aos="fade-up" data-aos-delay="200">

                        <a href="https://www.linkedin.com/in/mketiku/" target="_blank"
                            class="btn btn-lg px-4 btn-outline-secondary">
                            LinkedIn <i class="fab fa-linkedin ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
