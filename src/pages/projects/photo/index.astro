---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title="Photography | Michael Ketiku" simpleFooter={true}>
    <main class="flex-grow-1" style="padding-top: 100px;">
        <div class="container py-5">
            <div class="row justify-content-center mb-5">
                <div class="col-lg-8 text-center">
                    <h1 class="display-4 fw-bold mb-3" data-aos="fade-up">Photography</h1>
                    <p class="lead text-secondary" data-aos="fade-up" data-aos-delay="100">
                        Exploring the world through my lens.
                    </p>
                </div>
            </div>

            <div class="row justify-content-center mb-5" data-aos="fade-up">
                <div class="col-lg-10">
                    <div class="row g-4">
                        <div class="col-md-4" data-aos="fade-up" data-aos-delay="0">
                            <div class="photo-card rounded-3 shadow-sm">
                                <img src="https://placehold.co/800x600" alt="New York City">
                                <div class="photo-overlay text-white">
                                    <h5 class="mb-1">NYC Candid</h5>
                                    <p class="small mb-0 opacity-75"><i class="fas fa-camera me-1"></i> Canon T5 • 50mm</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                            <div class="photo-card rounded-3 shadow-sm">
                                <img src="https://placehold.co/800x600" alt="Architecture">
                                <div class="photo-overlay text-white">
                                    <h5 class="mb-1">Architecture</h5>
                                    <p class="small mb-0 opacity-75"><i class="fas fa-camera me-1"></i> Canon T5 • 18-55mm</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                            <div class="photo-card rounded-3 shadow-sm">
                                <img src="https://placehold.co/800x600" alt="Portraits">
                                <div class="photo-overlay text-white">
                                    <h5 class="mb-1">Portraits</h5>
                                    <p class="small mb-0 opacity-75"><i class="fas fa-camera me-1"></i> Canon T5 • 85mm</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container pb-5">
            <div class="row g-5 mb-5">
                <div class="col-md-6" data-aos="fade-right">
                    <h2 class="h3 text-theme mb-4">My Interests</h2>
                    <p class="text-secondary fs-5">
                        I love capturing candid moments in New York City, exploring architecture like bridges and
                        buildings, and most of all, taking portraits of my loved ones.
                    </p>
                    <p class="text-secondary fs-5">
                        I enjoy both color and black &amp; white photography. Currently, I am diving deeper into Lightroom
                        and general photography techniques, so I'm always open to tips and information!
                    </p>
                    <p class="text-secondary fs-5">I am currently curating a gallery of my best shots. In the meantime,
                        follow my journey on Instagram.</p>
                    <a href="https://www.instagram.com/iamoooko" target="_blank"
                        class="btn btn-outline-theme btn-lg rounded-pill px-4">
                        <i class="fab fa-instagram me-2"></i> Instagram
                    </a>
                </div>
                <div class="col-md-6" data-aos="fade-left">
                    <div class="card h-100 p-4 bg-body-tertiary border-0 shadow-sm">
                        <h3 class="h4 mb-4"><i class="fas fa-camera text-theme me-2"></i>Gear</h3>
                        <h5 class="h6 text-uppercase text-secondary mb-3">Current Setup</h5>
                        <ul class="list-unstyled">
                            <li class="mb-3 d-flex align-items-center">
                                <i class="fas fa-circle-dot text-secondary me-3 small"></i>
                                <strong>Canon EOS R7</strong>
                            </li>
                            <li class="mb-2 ms-4 text-secondary">Sigma 30mm f/1.4 DC DN</li>
                            <li class="mb-2 ms-4 text-secondary">Sigma 18-50mm f/2.8 DC DN</li>

                            <li class="mb-3 d-flex align-items-center mt-3">
                                <i class="fas fa-circle-dot text-secondary me-3 small"></i>
                                <strong>Canon EOS Rebel T5</strong>
                            </li>
                            <li class="mb-2 ms-4 text-secondary">EF 50mm f/1.8</li>
                            <li class="mb-2 ms-4 text-secondary">EF-S 75-300mm f/4-5.6</li>

                            <li class="mb-3 d-flex align-items-center mt-3">
                                <i class="fas fa-circle-dot text-secondary me-3 small"></i>
                                <strong>Olympus OM-1 Film Camera</strong>
                            </li>
                            <li class="mb-2 ms-4 text-secondary">Zuiko 50mm f/1.8</li>

                            <li class="mb-3 d-flex align-items-center mt-3">
                                <i class="fas fa-circle-dot text-secondary me-3 small"></i>
                                <strong>iPhone 15 Pro</strong>
                            </li>
                        </ul>
                        <hr class="my-4 opacity-25">
                        <h5 class="h6 text-uppercase text-secondary mb-3">Studio &amp; Supporting Gear</h5>
                        <ul class="list-unstyled">
                            <li class="mb-2 ms-4 text-secondary">Godox Litemons LA150D Daylight LED Light</li>
                            <li class="mb-2 ms-4 text-secondary">Impact Heavy-Duty Air-Cushioned Light Stand</li>
                            <li class="mb-2 ms-4 text-secondary">Godox Softbox</li>
                            <li class="mb-2 ms-4 text-secondary">Impact Reflector</li>
                            <li class="mb-2 ms-4 text-secondary">Backdrop</li>
                        </ul>
                        <hr class="my-4 opacity-25">
                        <h5 class="h6 text-uppercase text-secondary mb-3">Wishlist</h5>
                        <ul class="list-unstyled">
                            <li class="mb-2 ms-4 text-secondary">External Flash</li>
                            <li class="mb-2 ms-4 text-secondary">Tripod</li>
                            <li class="mb-2 ms-4 text-secondary">UV &amp; Polarizer Filters</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </main>
</BaseLayout>
