---
interface Props {
  simple?: boolean;
}
const { simple = false } = Astro.props;
---

{simple ? (
    <footer class="bg-body text-secondary py-4 border-top mt-auto text-center">
        <div class="container small">
            &copy; 2026 Michael Ketiku
        </div>
    </footer>
) : (
    <footer class="bg-body text-secondary py-5 border-top">
        <div class="container">
            <div class="row gy-4">
                <div class="col-md-6">
                    <h5 class="text-body-emphasis mb-3">Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a href="/#about">About</a></li>
                        <li><a href="/#experience">Experience</a></li>
                        <li><a href="/#projects">Projects</a></li>
                        <li><a href="/#education">Education</a></li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <h5 class="text-body-emphasis mb-3">Connect</h5>
                    <ul class="list-unstyled">
                        <li><a href="#" class="js-email-link" data-u="mketiku" data-d="gmail.com">Email</a></li>
                        <li><a href="https://www.linkedin.com/in/mketiku/" target="_blank">LinkedIn Profile</a></li>
                        <li><a href="https://github.com/mketiku" target="_blank">GitHub Profile</a></li>
                    </ul>
                </div>
            </div>
            <div class="text-center mt-5 pt-3 border-top small">
                &copy; 2026 Michael Ketiku
            </div>
        </div>
    </footer>
)}
