---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/main.css';

interface Props {
  title: string;
  description?: string;
  simpleFooter?: boolean;
  scrollSpy?: boolean;
}

const {
  title,
  description = 'Michael Ketiku — Senior Software Engineer based in New York.',
  simpleFooter = false,
  scrollSpy = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🪪</text></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <noscript>
        <style>
            [data-aos] {
                opacity: 1 !important;
                transform: none !important;
            }
        </style>
    </noscript>
    <slot name="head" />
</head>

<body
    class:list={['d-flex flex-column min-vh-100', scrollSpy && 'data-bs-spy']}
    {...scrollSpy ? { 'data-bs-spy': 'scroll', 'data-bs-target': '#navbarNav', 'data-bs-offset': '100' } : {}}
>
    <Navbar />
    <slot />
    <Footer simple={simpleFooter} />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" is:inline></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js" is:inline></script>
    <script src="/app.js" is:inline></script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QY66C7CZBQ"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-QY66C7CZBQ');
    </script>
</body>
</html>
